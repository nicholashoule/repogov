#!/bin/sh
# pre-commit hook -- runs repogov checks via the CLI.
# Works on Linux, macOS, and Windows (via Git for Windows' bundled sh.exe).
#
# Install once with: make hooks
root="$(git rev-parse --show-toplevel)"
cd "$root"

go run ./cmd/repogov all
repogov_exit=$?

# Audit only -- demojify must be installed: go install github.com/nicholashoule/demojify-sanitize/cmd/demojify@latest
# Using -fix here would rewrite the working tree without re-staging, leaving the index still dirty.
demojify_exit=0
if command -v demojify >/dev/null 2>&1; then
  demojify -quiet
  demojify_exit=$?
  if [ "$demojify_exit" -ne 0 ]; then
    echo "ERROR: emoji found -- fix and re-stage before committing:"
    echo "  demojify -fix && git add -u"
  fi
else
  echo "ERROR: demojify command not found on PATH."
  echo "Install it with:"
  echo "  go install github.com/nicholashoule/demojify-sanitize/cmd/demojify@latest"
  demojify_exit=1
fi

go run "$root/scripts/hooks/pre-commit.go"
precommit_exit=$?

exit $((repogov_exit | demojify_exit | precommit_exit))
