#!/bin/sh
# pre-commit hook -- runs repogov checks via the CLI.
# Works on Linux, macOS, and Windows (via Git for Windows' bundled sh.exe).
#
# Install once with: make hooks
root="$(git rev-parse --show-toplevel)"
cd "$root"

# Run repogov governance checks (line limits + layout) using the tagged release.
# If the module cannot be fetched the check will fail with a descriptive error.
repogov_ref="github.com/nicholashoule/repogov/cmd/repogov@v0.7.0"
go run "$repogov_ref" -root "$root" -agent copilot
repogov_exit=$?
if [ "$repogov_exit" -ne 0 ]; then
  echo "ERROR: repogov checks failed. To fix, run:"
  echo "  go run $repogov_ref -root \"$root\" -agent copilot"
fi

# Run demojify-sanitize. If emoji are found, substitute them automatically,
# re-stage the modified files, and abort the commit so the user can review
# the substitutions before re-committing.
demojify_ref="github.com/nicholashoule/demojify-sanitize/cmd/demojify@v0.7.2"
go run "$demojify_ref" -root "$root"
demojify_exit=$?
if [ "$demojify_exit" -ne 0 ]; then
  echo "INFO: emoji found -- running -sub to substitute and re-staging changes..."
  go run "$demojify_ref" -root "$root" -sub
  git add -u
  echo "ERROR: emoji were substituted and re-staged. Review the changes and re-commit."
fi

# precommit_exit covers gofmt, go vet, go test, and golangci-lint (via checkLint in pre-commit.go).
go run "$root/scripts/hooks/pre-commit.go"
precommit_exit=$?

exit $((repogov_exit | demojify_exit | precommit_exit))
